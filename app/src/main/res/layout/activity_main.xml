<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingBottom="12dp"
        android:text="IP Watcher" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:paddingBottom="16dp"
        android:textColor="#888888"
        android:text="App tự kiểm tra IP hiện tại, nếu không khớp dải mong muốn sẽ tự bật/tắt Airplane Mode để đổi IP. Cơ chế: đăng ký làm Trợ lý số mặc định (không cần root, không cần ADB)." />

    <TextView
        android:id="@+id/tvAssistantStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:paddingBottom="8dp"
        android:text="Trạng thái: đang kiểm tra…" />

    <Button
        android:id="@+id/btnSetAssistant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="Đặt làm Trợ lý mặc định" />

    <Button
        android:id="@+id/btnTestToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#555555"
        android:text="Test Toggle (bật máy bay 3s rồi tắt)" />

    <EditText
        android:id="@+id/editPrefix"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Dải IP mong muốn, ví dụ: 42. hoặc 118.70" />

    <EditText
        android:id="@+id/editInterval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:inputType="number"
        android:hint="Khoảng thời gian kiểm tra (giây), ví dụ 5" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Lưu cấu hình" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Bắt đầu theo dõi" />

    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Dừng" />

</LinearLayout>
</ScrollView>
